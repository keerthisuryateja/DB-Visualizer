{
  "name": "db-visualizer",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop data exploration app for CSV and JSON with query, analytics, and export support.",
  "author": "Keerth Surya Teja",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev:desktop": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build": "tsc && vite build",
    "build:desktop": "npm run build && electron-builder --win --dir --publish never",
    "build:installer": "npm run build && electron-builder --publish never",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "com.db.visualizer",
    "productName": "DB Visualizer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  }
}
